# ─────────────────────────────────────────────────────────────
# AI Resume Builder — Environment Variables
# ─────────────────────────────────────────────────────────────
# 1. Copy this file: cp .env.example .env
# 2. Fill in your real values below
# 3. NEVER commit .env to git
# ─────────────────────────────────────────────────────────────

# ── OpenRouter (REQUIRED) ────────────────────────────────────
# Get your key at: https://openrouter.ai/keys
# Free credits available on sign-up
OPENROUTER_API_KEY=

# AI model to use for resume tailoring and evaluation
# Recommended: google/gemini-2.0-flash-001 (fast + cheap, ~$0.001/run)
# Alternatives: anthropic/claude-haiku-4-5, openai/gpt-4o-mini
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# ── Tavily Web Search (OPTIONAL but recommended) ─────────────
# Used to research the company before tailoring
# Get your key at: https://tavily.com (free tier: 1,000 searches/month)
# If left empty, the script skips company research and tailors from JD only
TAVILY_API_KEY=

# ── Google OAuth2 (REQUIRED for Google Docs output) ──────────
# DO NOT fill these in manually.
# Run: python scripts/auth_google.py
# That script will open your browser, you log in once,
# and it will automatically write the 3 values below into this file.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# ── Google Drive Folder (OPTIONAL) ───────────────────────────
# If set, all generated resumes will be saved inside this folder
# To get a folder ID: open the folder in Google Drive, copy the ID from the URL
# Example URL: https://drive.google.com/drive/folders/1A2B3C4D5E6F
# Leave empty to save to the root of your Google Drive
GOOGLE_DRIVE_FOLDER_ID=
